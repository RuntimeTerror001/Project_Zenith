# =========================================================================
# Project Zenith Environment Variables Configuration Template
# =========================================================================

# -------------------------------------------------------------------------
# Frontend (Next.js) Variables
# -------------------------------------------------------------------------
# NASA API Key (optional, defaults to DEMO_KEY, but subject to rate limits)
NASA_API_KEY=DEMO_KEY

# Public site domain for SEO metadata and absolute pathing (optional in local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL of your deployed Express backend (required in production)
BACKEND_URL=http://localhost:5001
NEXT_PUBLIC_BACKEND_URL=http://localhost:5001


# -------------------------------------------------------------------------
# Backend (Express Node.js Server) Variables
# -------------------------------------------------------------------------
# Port on which the backend server will run
PORT=5001

# MongoDB Connection String
MONGO_URI=mongodb://127.0.0.1:27017/project_zenith

# JSON Web Token secret key for user registration, authentication, and profiles
JWT_SECRET=super_secret_cosmos_key_zenith_12345
